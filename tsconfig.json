{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/image-puzzle/src/*"],
      "@core-hubble/prisma": ["libs/prisma/src/index.ts"],
      "@core-hubble/auth": ["libs/auth/src/index.ts"],
      "@core-hubble/utils": ["libs/utils/src/index.ts"],
      "@core-hubble/context": ["libs/context/src/index.ts"]
    }
  },
  "include": [
    "apps/image-puzzle/src/**/*.ts",
    "apps/image-puzzle/src/**/*.tsx",
    "libs/**/*.ts",
    "libs/**/*.tsx"
  ],
  "exclude": ["node_modules", "tmp", "dist"]
}
