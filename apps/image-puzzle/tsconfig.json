{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core-hubble/prisma": ["../../libs/prisma/src/index.ts"],
      "@core-hubble/auth": ["../../libs/auth/src/index.ts"],
      "@core-hubble/utils": ["../../libs/utils/src/index.ts"],
      "@core-hubble/context": ["../../libs/context/src/index.ts"]
    }
  },
  "include": [
    "../../next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
