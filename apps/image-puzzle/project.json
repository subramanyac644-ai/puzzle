{
  "name": "image-puzzle",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/image-puzzle/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "root": "apps/image-puzzle",
        "outputPath": "dist/apps/image-puzzle"
      },
      "configurations": {
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "image-puzzle:build",
        "dev": true
      },
      "configurations": {
        "development": {
          "buildTarget": "image-puzzle:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "image-puzzle:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/image-puzzle/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}
